{
  "name": "contract-pdf",
  "version": "1.0.0",
  "private": true,
  "description": "PDF generator for Arztpraxis Öffentlichkeitsarbeit Vertrag",
  "type": "module",
  "scripts": {
    "build": "node src/generate.js",
