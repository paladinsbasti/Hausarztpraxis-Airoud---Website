# Hausarztpraxis Airoud - Environment Configuration
# Kopieren Sie diese Datei zu .env und passen Sie die Werte an

# === SERVER CONFIGURATION ===
NODE_ENV=production
PORT=3000
HTTPS_PORT=443
HTTP_PORT=80

# === SSL CONFIGURATION ===
# SSL aktivieren (true für Produktion, false für Entwicklung)
USE_SSL=true

# HTTP zu HTTPS Weiterleitung aktivieren
REDIRECT_HTTP=true

# SSL-Zertifikat Pfade (relativ zum Projektordner)
SSL_KEY_PATH=./ssl/private.key
SSL_CERT_PATH=./ssl/certificate.crt
SSL_CA_PATH=./ssl/ca_bundle.crt

# === SECURITY CONFIGURATION ===
# Session Secret (32-Byte kryptographisch sicher)
SESSION_SECRET=bBYOhT1vjPlWuwYnVdEMKVASnSFIM/YxsD3/aTzNKlU=

# Admin Credentials (bcrypt hash)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$moT6CpYfPZUTkak/gjbwSOhnk.QHJU3/y4aA1xbRMxz9Xm2zGNqRG

# === RATE LIMITING ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=3

# === FILE UPLOAD LIMITS ===
MAX_FILE_SIZE=2097152
MAX_FILES=5

# === LOGGING ===
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# === BACKUP CONFIGURATION ===
BACKUP_ENABLED=true
BACKUP_INTERVAL=24
BACKUP_RETENTION_DAYS=30
